# Copy to .env.local for local dev, or set these in Vercel > Project > Settings >
# Environment Variables. All are optional; the site runs without them.

# Canonical site URL, no trailing slash. Used for metadata, sitemap, robots, OG,
# and JSON-LD. REQUIRED on any deployment where NEXT_PUBLIC_SITE_INDUSTRY is set:
# without it the focused domain's pages canonicalize to https://oneby.ai and the
# site de-indexes itself. Set it to that deployment's own domain.
NEXT_PUBLIC_SITE_URL=https://oneby.ai

# Turn this deployment into a dedicated single-industry site. Set to an industry
# slug (hvac, plumbing, electricians, roofing, restoration, garage-door,
# pest-control, property-management, msp-it, law-firms, medical-offices) and the
# homepage becomes that industry, every other industry is hidden from
# nav/footer/sitemap, and other /industries/* URLs redirect to the root. Point a
# dedicated domain at it and it reads as a business that only serves that trade.
# Unset (or "all") = the full multi-industry OneBy site.
NEXT_PUBLIC_SITE_INDUSTRY=

# Google Analytics 4 measurement ID (G-XXXXXXXXXX). Unset = analytics disabled.
NEXT_PUBLIC_GA_ID=

# Google Search Console verification token. Emits the verification meta tag.
GOOGLE_SITE_VERIFICATION=

# ---- Lead delivery (/api/demo). Configure at least ONE or leads only land in
# server logs. Both can be set; each configured destination is attempted. ----
# Any webhook that accepts a JSON POST. Slack incoming-webhook URLs get a
# formatted message; anything else (Zapier, Make, Discord, CRM) gets raw JSON.
LEAD_WEBHOOK_URL=
# Email delivery via resend.com (free tier is plenty). Create an API key, set
# the inbox that should receive leads. LEAD_EMAIL_FROM is optional — the
# default onboarding sender works until you verify your domain in Resend.
RESEND_API_KEY=
LEAD_EMAIL_TO=
LEAD_EMAIL_FROM=

# Stripe Payment Link for the refundable founder deposit. When set, the founder
# "Reserve" buttons send people here to put a card down (the real willingness-to-
# pay signal). Unset = those buttons fall back to the demo/lead form. Create it
# in Stripe > Payment Links. NEVER put a secret key here; this is a public URL.
NEXT_PUBLIC_STRIPE_DEPOSIT_URL=
